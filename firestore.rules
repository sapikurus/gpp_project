rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Main app data — authenticated users only
    match /gpp/{doc} {
      allow read, write: if request.auth != null;
    }
    match /gpp/{doc}/{col}/{id} {
      allow read, write: if request.auth != null;
    }

    // FCM device tokens — users can write their own token
    match /fcm_tokens/{tokenId} {
      allow read: if false; // only Cloud Function reads these
      allow write: if request.auth != null;
    }

    // Notification requests — app creates, Cloud Function deletes
    match /notification_requests/{reqId} {
      allow create: if request.auth != null;
      allow read, delete: if false; // Cloud Function handles these
    }
  }
}
