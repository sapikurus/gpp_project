rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Main app data
    match /gpp/{doc} {
      allow read, write: if request.auth != null;
    }
    match /gpp/{doc}/{col}/{id} {
      allow read, write: if request.auth != null;
    }

    // FCM tokens — each user can read/write only their own token
    // Key format: email with dots replaced by underscores
    match /fcm_tokens/{tokenId} {
      allow read, write: if request.auth != null
        && tokenId == request.auth.token.email.replace('.', '_');
    }

    // Notification requests — any authenticated user can create
    // Cloud Function deletes them (using Admin SDK, bypasses rules)
    match /notification_requests/{reqId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}
