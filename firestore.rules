rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Main app data — all authenticated users
    match /gpp/{doc} {
      allow read, write: if request.auth != null;
    }
    match /gpp/{doc}/{col}/{id} {
      allow read, write: if request.auth != null;
    }

    // FCM device tokens — any authenticated user can write their own token.
    // Reading is blocked for clients; Cloud Function uses Admin SDK which bypasses rules.
    match /fcm_tokens/{tokenId} {
      allow write: if request.auth != null;
      allow read:  if false;
    }

    // Notification requests — authenticated users create them,
    // Cloud Function (Admin SDK) reads and deletes them.
    match /notification_requests/{reqId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}
