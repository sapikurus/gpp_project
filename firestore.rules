rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Main app data
    match /gpp/{doc} {
      allow read, write: if request.auth != null;
    }
    match /gpp/{doc}/{col}/{id} {
      allow read, write: if request.auth != null;
    }

    // FCM device tokens — authenticated users write their own token
    // Cloud Function reads via Admin SDK (bypasses these rules)
    match /fcm_tokens/{tokenId} {
      allow write: if request.auth != null;
      allow read:  if false;
    }

    // Notification requests — authenticated users create + read (for CF polling test)
    // Only Admin SDK (Cloud Function) can delete
    match /notification_requests/{reqId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null;
      allow update, delete: if false;
    }
  }
}
